# Supabase — get these from the Supabase project dashboard (Settings → API)
# Public values are safe to expose in the browser.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only secret. NEVER expose to the browser. Required by the post
# dispatcher (/api/dispatch), "Send now", and the unsubscribe endpoint.
SUPABASE_SERVICE_ROLE_KEY=

# Public site URL (used for metadata / redirects / unsubscribe links),
# e.g. https://christiesgolfranch.com
NEXT_PUBLIC_SITE_URL=

# --- Posting engine (BUILDSTATUS Phase 4) ---

# Shared secret that authorizes calls to /api/dispatch. Must match the value
# baked into the Supabase pg_cron job named 'dispatch-posts'.
CRON_SECRET=

# Resend (email channel) — from resend.com. RESEND_FROM must be a sender on a
# verified domain, e.g. "Christie's Golf Ranch <hello@christiesgolfranch.com>".
RESEND_API_KEY=
RESEND_FROM=

# Meta Graph API (Facebook + Instagram channels). Until these exist the
# channels show a clear "not connected yet" message instead of sending.
META_PAGE_ID=
META_PAGE_ACCESS_TOKEN=
META_IG_USER_ID=
