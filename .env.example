# Christie's Golf Ranch — environment variables
# Real values live in Vercel project env vars, never committed.
# This file documents every key with NO values.

# --- Phase 2: Clover Hosted Checkout ---
CLOVER_MERCHANT_ID=
CLOVER_PRIVATE_TOKEN=
CLOVER_ENVIRONMENT=        # "sandbox" or "production"
SITE_BASE_URL=             # e.g. https://christiesgolfranch.com (for redirect URLs)

# --- Phase 3: Capture + review/email engine ---
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=

# Email provider (Resend or Postmark)
RESEND_API_KEY=
# POSTMARK_SERVER_TOKEN=

# SMS (optional, opt-in only)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Google Business Profile review deep link
GOOGLE_REVIEW_LINK=
