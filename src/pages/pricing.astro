---
import Layout from '../layouts/Layout.astro';
const title = "Pricing — Christie's Golf Ranch | Range, Memberships, Lessons & Camp";
const description = "Posted pricing at Christie's Golf Ranch in Pilot Point, TX: range buckets, monthly memberships, private lessons with Jeff Christie, and junior camp. No surprises.";
---
<Layout title={title} description={description}>
  <section class="page-hero">
    <div class="wrap">
      <p class="crumbs"><a href="/">Home</a> · Pricing</p>
      <h1>Pricing</h1>
      <p class="lede">Posted rates, no surprises — range buckets, memberships, instruction, and junior camp all in one place.</p>
    </div>
  </section>
  <section class="section">
    <div class="wrap">
      <p class="stub-note">Full rate sheet coming next — building the Home page first for review. The complete pricing from the approved design will live here.</p>
      <div style="margin-top:1.8rem"><a class="btn btn-brass" href="/">Back to Home</a></div>
    </div>
  </section>
</Layout>
