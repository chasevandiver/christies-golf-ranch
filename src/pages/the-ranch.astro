---
import Layout from '../layouts/Layout.astro';
const title = "The Ranch — Christie's Golf Ranch | Driving Range & Par-3 in Pilot Point, TX";
const description = "Tour Christie's Golf Ranch: a 55-station all-grass driving range, 9-hole par-3 course, chipping and putting greens, bunkers and water on 15 acres in Pilot Point, TX.";
---
<Layout title={title} description={description}>
  <section class="page-hero">
    <div class="wrap">
      <p class="crumbs"><a href="/">Home</a> · The Ranch</p>
      <h1>The Ranch</h1>
      <p class="lede">A 55-station all-grass range, a 9-hole par-3 course, and dedicated short-game grounds across fifteen acres of Pilot Point horse country.</p>
    </div>
  </section>
  <section class="section">
    <div class="wrap">
      <p class="stub-note">Full facility page coming next — building the Home page first for review. The facility highlights, gallery, and grounds details from the approved design will live here.</p>
      <div style="margin-top:1.8rem"><a class="btn btn-brass" href="/">Back to Home</a></div>
    </div>
  </section>
</Layout>
