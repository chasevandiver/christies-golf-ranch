---
import Layout from '../layouts/Layout.astro';
import Photo from '../components/Photo.astro';
import Seal from '../components/Seal.astro';
import { site, addressLine } from '../config/site';

const title = "Christie's Golf Ranch — The Premier All-Grass Driving Range in North Texas";
const description =
  "North Texas's premier all-grass golf ranch — a 55-station driving range and 9-hole par-3 course on 15 acres of Pilot Point horse country. Instruction, memberships, junior camps. Open every day.";
---
<Layout title={title} description={description} path="/">
  <!-- HERO -->
  <section class="hero" id="top">
    <div class="hero-glow"></div>
    <!-- fence line: ranch / horse country -->
    <svg class="hero-fence" viewBox="0 0 1440 120" preserveAspectRatio="none" aria-hidden="true">
      <g stroke="#1C120A" stroke-width="6">
        <line x1="60" y1="40" x2="60" y2="120"/><line x1="220" y1="36" x2="220" y2="120"/>
        <line x1="380" y1="40" x2="380" y2="120"/><line x1="540" y1="34" x2="540" y2="120"/>
        <line x1="700" y1="40" x2="700" y2="120"/><line x1="860" y1="36" x2="860" y2="120"/>
        <line x1="1020" y1="40" x2="1020" y2="120"/><line x1="1180" y1="34" x2="1180" y2="120"/>
        <line x1="1340" y1="40" x2="1340" y2="120"/>
      </g>
      <g stroke="#1C120A" stroke-width="5">
        <line x1="0" y1="60" x2="1440" y2="56"/><line x1="0" y1="84" x2="1440" y2="80"/>
      </g>
    </svg>
    <div class="hero-inner">
      <div>
        <span class="kicker">Pilot Point, Texas · Est. {site.established}</span>
        <h1>The premier all-grass golf ranch in <em>North Texas.</em></h1>
        <p class="lede">A 55-station driving range and a 9-hole par-3 course spread across fifteen acres of open horse country — a serious place to practice, welcome to all, open every day.</p>
        <div class="hero-actions">
          <a class="btn btn-brass btn-lg" href="/pricing">View Pricing</a>
          <a class="btn btn-outline btn-lg" href="/visit">Hours &amp; Directions</a>
        </div>
      </div>
      <!-- BRANDING-IRON SEAL: the ranch signature -->
      <div class="hero-seal">
        <Seal variant="full" />
      </div>
    </div>
    <div class="hero-stats">
      <div class="stat"><div class="num">55</div><div class="lbl">Grass Stations</div></div>
      <div class="stat"><div class="num">9</div><div class="lbl">Hole Par-3</div></div>
      <div class="stat"><div class="num">15</div><div class="lbl">Acres</div></div>
      <div class="stat"><div class="num">Daily</div><div class="lbl">8am – Dark</div></div>
    </div>
  </section>

  <!-- ABOUT -->
  <section class="section" id="about">
    <div class="wrap about-grid">
      <div class="about-copy reveal">
        <span class="eyebrow">The Ranch</span>
        <h2>A first-class golf venue, built on family land</h2>
        <p>Christie's Golf Ranch is a one-of-a-kind driving range and nine-hole par-3 course nestled in the heart of horse country in Pilot Point. It began as the life-long dream of golf enthusiast Jeff Christie, who bought the land in 2008 and built the venue in honor of his late father, Jim Christie.</p>
        <p>Today it's a full-service, all-grass practice facility — fifty-five stations, a pro shop, professional instruction, memberships, and a junior camp — where individuals, groups, and families build real skills on well-kept grounds.</p>
        <p class="sig">"There are not many people living out their dream. I am doing that." — Jeff Christie</p>
        <div style="margin-top:1.8rem">
          <a class="btn btn-dark" href="/our-story">Read Our Story</a>
        </div>
      </div>
      <Photo class="reveal" marker="the range at first light" tag="the range at first light" scene="range" />
    </div>
  </section>

  <!-- FACILITY -->
  <section class="section on-dark" id="range">
    <div class="wrap">
      <div class="reveal">
        <span class="eyebrow">The Facility</span>
        <h2>Every part of the game, on real Texas grass</h2>
        <p class="intro">Fifteen acres purpose-built for practice — from the long ball to the short game, everything that holds up on the course.</p>
      </div>
      <div class="feat-grid reveal">
        <div class="feat"><div class="ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M12 2v13"/><path d="M12 2l7 2.5L12 7"/><ellipse cx="12" cy="19" rx="7" ry="2.5"/></svg></div><h3>55 grass stations</h3><p>A full-service, all-grass range — never off a mat. Buckets from 75 to 150 balls.</p></div>
        <div class="feat"><div class="ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><circle cx="12" cy="12" r="9"/><path d="M12 3a15 15 0 0 1 0 18M12 3a15 15 0 0 0 0 18M3 12h18"/></svg></div><h3>9-hole par-3 course</h3><p>Greens with genuine slope and pin variety. Open for events and monthly Play Days.</p></div>
        <div class="feat"><div class="ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M5 18c0-4 3-7 7-7s7 3 7 7"/><path d="M3 18h18"/><circle cx="12" cy="8" r="2"/></svg></div><h3>Chipping &amp; putting greens</h3><p>Dedicated short-game areas to sharpen the shots that actually lower scores.</p></div>
        <div class="feat"><div class="ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M2 16c4-6 8 4 12-2s6 2 8-2"/><path d="M2 20h20"/></svg></div><h3>Bunkers &amp; water</h3><p>Practice from the sand and around the water, so nothing surprises you in a round.</p></div>
        <div class="feat"><div class="ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M12 2l3 7 7 .5-5.5 4.5L18 21l-6-4-6 4 1.5-7L2 9.5 9 9z"/></svg></div><h3>Three 60+ yard holes</h3><p>Real practice holes bridging the gap between the range and the course.</p></div>
        <div class="feat"><div class="ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M3 9l9-6 9 6v11a1 1 0 0 1-1 1H4a1 1 0 0 1-1-1z"/><path d="M9 21v-6h6v6"/></svg></div><h3>Pro shop</h3><p>What you need on the way in — plus details on clinics, events, and parties.</p></div>
      </div>
      <div class="reveal" style="margin-top:2.6rem">
        <a class="btn btn-brass" href="/the-ranch">Explore the Facility</a>
      </div>
    </div>
  </section>

  <!-- PRICING SNAPSHOT -->
  <section class="section" id="pricing">
    <div class="wrap">
      <div class="reveal">
        <span class="eyebrow">Membership &amp; Rates</span>
        <h2>Posted pricing, no surprises</h2>
        <p class="intro">No membership required to walk up and hit balls — but for regulars, it pays off fast. A snapshot below; see the full rate sheet for instruction and camps.</p>
      </div>

      <div class="price-band reveal">
        <div class="band-head"><h3>At the range</h3><span class="note">Open daily · 8am – dark</span></div>
        <div class="pgrid c2">
          <div class="pcard"><h4>Small bucket</h4><div class="amt">$17</div><p class="desc">75 balls — a focused warm-up or a quick evening session.</p></div>
          <div class="pcard"><h4>Large bucket</h4><div class="amt">$25</div><p class="desc">150 balls — settle in and groove the swing.</p></div>
        </div>
      </div>

      <div class="price-band reveal">
        <div class="band-head"><h3>Memberships</h3><span class="note">3-month minimum · unlimited range balls</span></div>
        <div class="pgrid c2">
          <div class="pcard">
            <h4>Practice Membership</h4>
            <div class="amt">$90<span> / month</span></div>
            <ul>
              <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>Unlimited use of the practice facility</li>
              <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>Unlimited range balls</li>
            </ul>
            <!-- Phase 2: replace with Clover Hosted Checkout button. -->
            <div class="cta"><a class="btn btn-dark" href={site.phoneHref}>Inquire to Join</a></div>
          </div>
          <div class="pcard hi">
            <span class="flag">Best value</span>
            <h4>Practice + Monthly Lesson</h4>
            <div class="amt">$130<span> / month</span></div>
            <ul>
              <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>Unlimited practice &amp; range balls</li>
              <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>One 30-minute lesson every month</li>
            </ul>
            <!-- Phase 2: replace with Clover Hosted Checkout button. -->
            <div class="cta"><a class="btn btn-brass" href={site.phoneHref}>Inquire to Join</a></div>
          </div>
        </div>
      </div>

      <div class="reveal" style="margin-top:2.6rem">
        <a class="btn btn-dark" href="/pricing">See Full Pricing</a>
      </div>
    </div>
  </section>

  <!-- PLAY DAY -->
  <section class="section on-dark playday">
    <div class="wrap">
      <div class="copy reveal">
        <span class="eyebrow">Last Friday, every month</span>
        <h2>Monthly Play Day on the par-3</h2>
        <p class="intro">Unlimited golf on the nine-hole, par-3 course — real greens, real slopes, no tee times. Just ride up and play. The course opens for events like this; the range is open daily.</p>
      </div>
      <div class="price reveal"><div class="big">$25</div><div class="sub">Unlimited play · per golfer</div></div>
    </div>
  </section>

  <!-- MISSION -->
  <section class="section mission">
    <div class="wrap reveal">
      <span class="eyebrow">Our Purpose</span>
      <blockquote>"My mission is to teach young men and women self-worth through Jesus Christ — living it every day by giving God the glory and welcoming those He puts in front of me."</blockquote>
      <p class="verse">"Commit your works to the Lord, and your plans will be established." — Proverbs 16:3</p>
      <cite>Jeff Christie · Founder</cite>
    </div>
  </section>

  <!-- TESTIMONIALS -->
  <section class="section on-dark" id="reviews">
    <div class="wrap">
      <div class="reveal">
        <span class="eyebrow">From Our Golfers</span>
        <h2>What members and visitors say</h2>
      </div>
      <div class="quotes reveal">
        <div class="quote"><div class="stars">★★★★★</div><p>"Paste Randy's actual review wording here."</p><span class="who">Randy</span></div>
        <div class="quote"><div class="stars">★★★★★</div><p>"Paste Chuck's actual review wording here."</p><span class="who">Chuck</span></div>
        <div class="quote"><div class="stars">★★★★★</div><p>"Paste Husker's actual review wording here."</p><span class="who">Husker</span></div>
      </div>
      <!-- DRAFT: review — placeholder testimonials. Drop in real Google review wording. Genuine reviews only. -->
      <p class="editnote reveal" style="color:var(--cream-soft);border-color:var(--brass)">Your current site lists these names but the quote text came through garbled. Drop in the real wording, or pull your strongest recent Google reviews. Genuine reviews only.</p>
    </div>
  </section>

  <!-- VISIT -->
  <section class="section on-dark" id="visit" style="background:var(--leather-soft)">
    <div class="wrap">
      <div class="reveal">
        <span class="eyebrow">Visit</span>
        <h2>Ride out and see the ranch</h2>
      </div>
      <div class="visit-grid">
        <div class="reveal">
          <div class="irow"><div class="ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg></div><div><h4>Location</h4><p>{site.address.street}<br>{site.address.locality}, {site.address.regionName} {site.address.postalCode}</p></div></div>
          <div class="irow"><div class="ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="12" cy="12" r="9"/><polyline points="12 7 12 12 16 14"/></svg></div><div><h4>Hours</h4><p>Driving range — {site.hours.rangeHuman.toLowerCase()}<br>Par-3 course — {site.hours.courseHuman.toLowerCase()}</p></div></div>
          <div class="irow"><div class="ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z"/></svg></div><div><h4>Call</h4><p><a href={site.phoneHref}>{site.phone}</a></p></div></div>
          <div class="irow"><div class="ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M4 4h16v16H4z"/><polyline points="22 6 12 13 2 6"/></svg></div><div><h4>Email</h4><p><a href={`mailto:${site.email}`}>{site.email}</a></p></div></div>
        </div>
        <div class="map-card reveal">
          <iframe title={`Map to ${site.name}`} loading="lazy" referrerpolicy="no-referrer-when-downgrade" src={site.links.map}></iframe>
        </div>
      </div>
    </div>
  </section>
</Layout>
