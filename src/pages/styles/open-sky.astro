---
import { site, addressLine } from '../../config/site';
const title = "Open Sky — Style A | Christie's Golf Ranch";
---
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex" />
  <title>{title}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,500;9..144,600;9..144,700&family=Nunito+Sans:wght@400;600;700;800&display=swap" rel="stylesheet" />
</head>
<body>
  <div class="bar">Style A · Open Sky — <a href="/styles">back to all styles</a></div>

  <header class="nav">
    <a class="brand" href="#top">
      <span class="bmark">⛳</span>
      <span>Christie's <b>Golf Ranch</b><small>{site.tagline}</small></span>
    </a>
    <nav class="links">
      <a href="#range">The Range</a>
      <a href="#pricing">Pricing</a>
      <a href="#learn">Lessons &amp; Camp</a>
      <a href="#visit">Visit</a>
    </nav>
    <a class="btn" href={site.phoneHref}>Call {site.phone}</a>
  </header>

  <!-- HERO -->
  <section class="hero" id="top">
    <div class="hero-copy">
      <span class="pill">Pilot Point, Texas · Family-owned since {site.established}</span>
      <h1>Golf that's <em>easy to walk up to.</em></h1>
      <p>A 55-station all-grass driving range and a friendly 9-hole par-3 course on fifteen wide-open acres. No pressure, no stuffiness — just a great place to hit balls, take a lesson, and have fun. Open every day.</p>
      <div class="cta-row">
        <a class="btn big" href="#pricing">See Pricing</a>
        <a class="btn big ghost" href="#visit">Hours &amp; Directions</a>
      </div>
    </div>
    <div class="hero-art" aria-hidden="true">
      <div class="sun"></div>
      <div class="hill h1"></div>
      <div class="hill h2"></div>
      <div class="flag"><span class="pole"></span><span class="cloth"></span></div>
    </div>
  </section>

  <!-- STATS -->
  <section class="stats">
    <div><b>55</b><span>grass stations</span></div>
    <div><b>9</b><span>hole par-3</span></div>
    <div><b>15</b><span>acres</span></div>
    <div><b>Daily</b><span>8am – dark</span></div>
  </section>

  <!-- FEATURES -->
  <section class="section" id="range">
    <p class="eye">The Range</p>
    <h2>Everything you need to get better</h2>
    <div class="cards">
      <div class="c"><span class="ico">🌱</span><h3>All-grass stations</h3><p>Hit off real turf, never a mat — 55 stations with plenty of room.</p></div>
      <div class="c"><span class="ico">⛳</span><h3>9-hole par-3</h3><p>Real greens and slopes. Open for events and the monthly Play Day.</p></div>
      <div class="c"><span class="ico">🎯</span><h3>Short-game greens</h3><p>Chipping and putting areas to sharpen the shots that lower scores.</p></div>
      <div class="c"><span class="ico">🏌️</span><h3>Lessons for all ages</h3><p>Private coaching with Jeff — beginners and families always welcome.</p></div>
    </div>
  </section>

  <!-- PRICING -->
  <section class="section tint" id="pricing">
    <p class="eye">Simple Pricing</p>
    <h2>Posted rates, no surprises</h2>
    <div class="price-grid">
      <div class="price">
        <h3>At the range</h3>
        <ul>
          <li><span>Small bucket · 75 balls</span><b>$17</b></li>
          <li><span>Large bucket · 150 balls</span><b>$25</b></li>
        </ul>
        <p class="note">Walk up any day — no membership required.</p>
      </div>
      <div class="price feature">
        <span class="tag">Most popular</span>
        <h3>Membership</h3>
        <ul>
          <li><span>Practice · unlimited balls</span><b>$90<i>/mo</i></b></li>
          <li><span>Practice + monthly lesson</span><b>$130<i>/mo</i></b></li>
        </ul>
        <p class="note">3-month minimum. Unlimited range balls every visit.</p>
        <!-- Phase 2: Clover Hosted Checkout button replaces this. -->
        <a class="btn" href={site.phoneHref}>Join by phone</a>
      </div>
      <div class="price">
        <h3>Monthly Play Day</h3>
        <ul>
          <li><span>Unlimited par-3 golf</span><b>$25</b></li>
        </ul>
        <p class="note">Last Friday of every month — no tee times, just ride up and play.</p>
      </div>
    </div>
  </section>

  <!-- LEARN -->
  <section class="section" id="learn">
    <div class="split">
      <div>
        <p class="eye">Lessons</p>
        <h2>Private coaching with Jeff Christie</h2>
        <p class="lead">Golf is a mental game. Jeff builds on the skills you already have instead of tearing your swing apart — for individuals, families, and the local high school team.</p>
        <ul class="ticks">
          <li>Single hour — $95</li>
          <li>3 lessons — $270 · 5 lessons — $425 · 7 lessons — $560</li>
        </ul>
        <a class="btn" href={site.phoneHref}>Book a lesson</a>
      </div>
      <div class="camp">
        <p class="eye">Junior Camp</p>
        <h2>A great first start for kids</h2>
        <p class="lead">Ages 8–12 · 4-day camps · 2 hours a day. Etiquette, the rules, grip, posture and full-swing basics — taught in small groups with lots of reps.</p>
        <!-- DRAFT: confirm 2026 camp dates & price before launch. -->
        <a class="btn ghost" href={site.links.juniorCampForm} target="_blank" rel="noopener">Register for 2026</a>
      </div>
    </div>
  </section>

  <!-- VISIT -->
  <section class="section tint" id="visit">
    <p class="eye">Visit</p>
    <h2>Come see us in Pilot Point</h2>
    <div class="visit">
      <div class="info">
        <p><b>Where</b><br>{addressLine}</p>
        <p><b>Hours</b><br>Range — {site.hours.rangeHuman.toLowerCase()}<br>Course — {site.hours.courseHuman.toLowerCase()}</p>
        <p><b>Call</b><br><a href={site.phoneHref}>{site.phone}</a></p>
        <p><b>Email</b><br><a href={`mailto:${site.email}`}>{site.email}</a></p>
      </div>
      <div class="mapwrap">
        <iframe title="Map" loading="lazy" referrerpolicy="no-referrer-when-downgrade" src={site.links.map}></iframe>
      </div>
    </div>
  </section>

  <footer class="foot">
    <p>Christie's Golf Ranch · {addressLine} · {site.phone}</p>
    <p class="small">Style A draft — not the live site. <a href="/styles">Compare all three styles</a></p>
  </footer>

  <style is:global>
    *{box-sizing:border-box}
    body{margin:0;font-family:'Nunito Sans',system-ui,sans-serif;color:#27332b;background:#fff;line-height:1.6}
    h1,h2,h3{font-family:'Fraunces',serif;line-height:1.1;margin:0}
    a{color:inherit}
  </style>
  <style>
    :root{--sky:#3FA0D6;--grass:#2E7D52;--grass-d:#16493a;--sand:#F4EAD2;--ink:#27332b;--soft:#5d6b60}
    .bar{background:#16493a;color:#cfe6d6;text-align:center;font-size:.8rem;font-weight:700;padding:.5rem;letter-spacing:.03em}
    .bar a{color:#9ed3b0}

    .nav{position:sticky;top:0;z-index:20;display:flex;align-items:center;justify-content:space-between;gap:1rem;padding:.9rem clamp(16px,4vw,40px);background:rgba(255,255,255,.86);backdrop-filter:blur(10px);border-bottom:1px solid #e9efe9}
    .brand{display:flex;align-items:center;gap:.6rem;text-decoration:none;font-family:'Fraunces',serif;font-size:1.1rem;color:var(--grass-d)}
    .brand b{font-weight:700}
    .brand small{display:block;font-family:'Nunito Sans';font-size:.6rem;font-weight:800;letter-spacing:.18em;text-transform:uppercase;color:var(--grass)}
    .bmark{font-size:1.4rem}
    .links{display:flex;gap:1.6rem}
    .links a{text-decoration:none;font-weight:700;font-size:.9rem;color:var(--soft)}
    .links a:hover{color:var(--grass)}
    @media(max-width:780px){.links{display:none}}

    .btn{display:inline-flex;align-items:center;justify-content:center;gap:.4rem;background:var(--grass);color:#fff;text-decoration:none;font-weight:800;font-size:.9rem;padding:.7rem 1.3rem;border-radius:40px;border:2px solid var(--grass);transition:transform .15s,background .2s}
    .btn:hover{transform:translateY(-2px);background:var(--grass-d);border-color:var(--grass-d)}
    .btn.ghost{background:transparent;color:var(--grass-d);border-color:#cde0d2}
    .btn.ghost:hover{background:#eaf4ee;color:var(--grass-d)}
    .btn.big{padding:.95rem 1.8rem;font-size:1rem}

    .hero{position:relative;display:grid;grid-template-columns:1.1fr .9fr;gap:2rem;align-items:center;padding:clamp(3rem,7vw,6rem) clamp(16px,5vw,60px);background:linear-gradient(165deg,#EAF6FC 0%,#F4FBF2 60%,#FBF6E8 100%);overflow:hidden}
    .pill{display:inline-block;background:#fff;border:1px solid #d7e7dd;color:var(--grass-d);font-weight:800;font-size:.74rem;letter-spacing:.08em;text-transform:uppercase;padding:.45rem .9rem;border-radius:30px}
    .hero h1{font-size:clamp(2.6rem,6vw,4.6rem);font-weight:700;margin:1.3rem 0 0;color:var(--grass-d);letter-spacing:-.02em}
    .hero h1 em{font-style:italic;color:var(--sky)}
    .hero-copy p{font-size:1.15rem;color:var(--soft);max-width:46ch;margin:1.2rem 0 0}
    .cta-row{display:flex;flex-wrap:wrap;gap:.9rem;margin-top:2rem}
    .hero-art{position:relative;height:340px;border-radius:24px;background:linear-gradient(180deg,#bfe6fa,#eafbf0);overflow:hidden;box-shadow:0 30px 60px -30px rgba(22,73,58,.4)}
    .sun{position:absolute;top:38px;right:54px;width:84px;height:84px;border-radius:50%;background:radial-gradient(circle,#FFE7A6,#F6C863)}
    .hill{position:absolute;left:-5%;right:-5%;border-radius:50% 50% 0 0}
    .hill.h1{bottom:0;height:46%;background:#7cc49a}
    .hill.h2{bottom:0;height:30%;background:var(--grass)}
    .flag{position:absolute;bottom:26%;left:60%}
    .flag .pole{position:absolute;bottom:0;width:3px;height:120px;background:#3a4a3f;border-radius:2px}
    .flag .cloth{position:absolute;bottom:104px;left:3px;width:40px;height:24px;background:var(--sky);clip-path:polygon(0 0,100% 25%,0 55%)}
    @media(max-width:820px){.hero{grid-template-columns:1fr}.hero-art{height:240px}}

    .stats{display:flex;flex-wrap:wrap;justify-content:center;gap:clamp(1.5rem,6vw,4rem);padding:2.2rem 16px;background:var(--grass-d);color:#fff;text-align:center}
    .stats b{font-family:'Fraunces',serif;display:block;font-size:2.2rem;color:#FFD98A}
    .stats span{font-size:.78rem;font-weight:800;letter-spacing:.1em;text-transform:uppercase;color:#bfe0cb}

    .section{padding:clamp(3.5rem,7vw,6rem) clamp(16px,5vw,60px);max-width:1140px;margin:0 auto}
    .section.tint{max-width:none;background:#F4FBF2}
    .section.tint>*{max-width:1140px;margin-left:auto;margin-right:auto}
    .eye{font-weight:800;font-size:.78rem;letter-spacing:.16em;text-transform:uppercase;color:var(--grass);margin:0 0 .6rem}
    .section h2{font-size:clamp(1.8rem,4vw,2.8rem);font-weight:600;color:var(--grass-d);max-width:18ch}

    .cards{display:grid;grid-template-columns:repeat(4,1fr);gap:1.2rem;margin-top:2.5rem}
    @media(max-width:880px){.cards{grid-template-columns:1fr 1fr}}
    .c{background:#fff;border:1px solid #e7efe8;border-radius:18px;padding:1.6rem;box-shadow:0 14px 30px -22px rgba(22,73,58,.4)}
    .c .ico{font-size:1.8rem}
    .c h3{font-size:1.2rem;margin:.7rem 0 .4rem;color:var(--grass-d)}
    .c p{margin:0;color:var(--soft);font-size:.95rem}

    .price-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1.3rem;margin-top:2.5rem}
    @media(max-width:880px){.price-grid{grid-template-columns:1fr}}
    .price{position:relative;background:#fff;border:1px solid #e1ebe3;border-radius:20px;padding:1.8rem}
    .price.feature{border:2px solid var(--grass);box-shadow:0 20px 44px -26px rgba(46,125,82,.6)}
    .price .tag{position:absolute;top:-13px;left:1.8rem;background:var(--grass);color:#fff;font-size:.66rem;font-weight:800;letter-spacing:.1em;text-transform:uppercase;padding:.3rem .8rem;border-radius:20px}
    .price h3{font-size:1.3rem;color:var(--grass-d);margin-bottom:1rem}
    .price ul{list-style:none;padding:0;margin:0 0 1rem}
    .price li{display:flex;justify-content:space-between;align-items:baseline;gap:1rem;padding:.6rem 0;border-bottom:1px dashed #e3ebe4}
    .price li span{color:var(--soft);font-weight:600;font-size:.95rem}
    .price li b{font-family:'Fraunces',serif;font-size:1.5rem;color:var(--grass-d);white-space:nowrap}
    .price li b i{font-style:normal;font-size:.8rem;color:var(--soft)}
    .price .note{font-size:.85rem;color:var(--soft);margin:.4rem 0 1.2rem}
    .price .btn{width:100%}

    .split{display:grid;grid-template-columns:1fr 1fr;gap:2.5rem;align-items:start}
    @media(max-width:820px){.split{grid-template-columns:1fr}}
    .lead{color:var(--soft);font-size:1.05rem;margin:1rem 0 1.4rem;max-width:48ch}
    .ticks{list-style:none;padding:0;margin:0 0 1.6rem}
    .ticks li{padding:.5rem 0 .5rem 1.7rem;position:relative;font-weight:600;color:var(--ink)}
    .ticks li::before{content:"✓";position:absolute;left:0;color:var(--grass);font-weight:900}
    .camp{background:#fff;border:1px solid #e7efe8;border-radius:20px;padding:1.8rem}

    .visit{display:grid;grid-template-columns:1fr 1.2fr;gap:2rem;margin-top:2.4rem;align-items:stretch}
    @media(max-width:820px){.visit{grid-template-columns:1fr}}
    .info p{margin:0 0 1.1rem;color:var(--ink)}
    .info b{color:var(--grass);font-size:.74rem;letter-spacing:.12em;text-transform:uppercase}
    .info a{color:var(--grass-d);font-weight:700;text-decoration:none}
    .mapwrap{border-radius:18px;overflow:hidden;min-height:300px;border:1px solid #dde7df}
    .mapwrap iframe{width:100%;height:100%;min-height:300px;border:0;display:block}

    .foot{background:var(--grass-d);color:#cfe6d6;text-align:center;padding:2.4rem 16px}
    .foot p{margin:.3rem 0}
    .foot .small{font-size:.85rem;color:#9bc4a8}
    .foot a{color:#bfe9cd}
  </style>
</body>
</html>
