---
import { site, addressLine } from '../../config/site';
const title = "Texas Twilight — Style B | Christie's Golf Ranch";
---
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex" />
  <title>{title}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,500;0,700;0,800;1,500&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
</head>
<body>
  <div class="bar">Style B · Texas Twilight — <a href="/styles">back to all styles</a></div>

  <header class="nav">
    <a class="brand" href="#top">Christie's <span>Golf Ranch</span></a>
    <nav class="links">
      <a href="#range">The Range</a>
      <a href="#rates">Rates</a>
      <a href="#learn">Lessons</a>
      <a href="#visit">Visit</a>
    </nav>
    <a class="navtel" href={site.phoneHref}>{site.phone}</a>
  </header>

  <!-- HERO -->
  <section class="hero" id="top">
    <div class="dusk" aria-hidden="true"></div>
    <div class="ridge" aria-hidden="true"></div>
    <div class="hero-inner">
      <span class="kick">Pilot Point, Texas · Est. {site.established}</span>
      <h1>Hit balls<br><em>till the sun<br>goes down.</em></h1>
      <p>Fifty-five all-grass stations and a nine-hole par-3 course on fifteen acres of open horse country. A serious place to practice — welcoming to everyone, open every day from morning light to last shadow.</p>
      <div class="cta">
        <a class="btn" href="#rates">View Rates</a>
        <a class="btn line" href="#visit">Plan a Visit</a>
      </div>
    </div>
    <div class="hero-stats">
      <div><b>55</b><span>Grass stations</span></div>
      <div><b>9</b><span>Hole par-3</span></div>
      <div><b>15</b><span>Acres</span></div>
      <div><b>Daily</b><span>8am – dark</span></div>
    </div>
  </section>

  <!-- RANGE / EDITORIAL -->
  <section class="ed" id="range">
    <div class="ed-num">01</div>
    <div class="ed-body">
      <p class="eye">The Facility</p>
      <h2>Every part of the game, on real Texas grass</h2>
      <p class="lead">From the long ball to the short game, the grounds are built for practice that actually transfers to the course.</p>
      <div class="rows">
        <div class="row"><h3>All-grass driving range</h3><p>55 stations, never a mat. Buckets of 75 or 150 balls.</p></div>
        <div class="row"><h3>9-hole par-3 course</h3><p>Genuine greens and slopes — open for events and the monthly Play Day.</p></div>
        <div class="row"><h3>Short game &amp; bunkers</h3><p>Chipping and putting greens, sand and water to practice around.</p></div>
        <div class="row"><h3>Pro shop</h3><p>What you need on the way in, plus clinics, events and parties.</p></div>
      </div>
    </div>
  </section>

  <!-- RATES -->
  <section class="rates" id="rates">
    <div class="rates-head">
      <div class="ed-num light">02</div>
      <div>
        <p class="eye gold">Membership &amp; Rates</p>
        <h2>Posted pricing, no surprises</h2>
      </div>
    </div>
    <div class="rgrid">
      <div class="rcard">
        <h3>At the range</h3>
        <div class="line2"><span>Small bucket · 75 balls</span><b>$17</b></div>
        <div class="line2"><span>Large bucket · 150 balls</span><b>$25</b></div>
        <p class="rnote">Walk up any day — no membership required.</p>
      </div>
      <div class="rcard hot">
        <span class="ribbon">Best value</span>
        <h3>Membership</h3>
        <div class="line2"><span>Practice · unlimited balls</span><b>$90<i>/mo</i></b></div>
        <div class="line2"><span>Practice + monthly lesson</span><b>$130<i>/mo</i></b></div>
        <p class="rnote">3-month minimum. Unlimited range balls, every visit.</p>
        <!-- Phase 2: Clover Hosted Checkout button replaces this. -->
        <a class="btn sm" href={site.phoneHref}>Join by phone</a>
      </div>
      <div class="rcard">
        <h3>Monthly Play Day</h3>
        <div class="line2"><span>Unlimited par-3 golf</span><b>$25</b></div>
        <p class="rnote">Last Friday of every month. No tee times — just play.</p>
      </div>
    </div>
  </section>

  <!-- LEARN -->
  <section class="ed split" id="learn">
    <div class="learn-col">
      <div class="ed-num">03</div>
      <p class="eye">Instruction</p>
      <h2>Coaching with Jeff Christie</h2>
      <p class="lead">Golf is a mental game. Jeff sharpens the skills you already have rather than rebuilding from scratch — for individuals, families, and the local high school team.</p>
      <div class="line2"><span>Single hour</span><b>$95</b></div>
      <div class="line2"><span>3-lesson package</span><b>$270</b></div>
      <div class="line2"><span>5-lesson package</span><b>$425</b></div>
      <div class="line2"><span>7-lesson package</span><b>$560</b></div>
      <a class="btn sm" href={site.phoneHref} style="margin-top:1.4rem">Book a lesson</a>
    </div>
    <div class="learn-col camp">
      <p class="eye gold">Junior Camp</p>
      <h2>A foundation for the next generation</h2>
      <p class="lead">Ages 8–12 · 4-day camps · 2 hours daily. Etiquette, the rules, grip, posture and full-swing fundamentals — small groups, plenty of reps.</p>
      <!-- DRAFT: confirm 2026 camp dates & price before launch. -->
      <a class="btn line sm" href={site.links.juniorCampForm} target="_blank" rel="noopener">Register for 2026</a>
    </div>
  </section>

  <!-- MISSION -->
  <section class="mission">
    <p>“My mission is to teach young men and women self-worth through Jesus Christ — living it every day by giving God the glory and welcoming those He puts in front of me.”</p>
    <cite>Jeff Christie · Founder</cite>
  </section>

  <!-- VISIT -->
  <section class="visit" id="visit">
    <div class="vinfo">
      <p class="eye gold">Visit</p>
      <h2>Ride out and see the ranch</h2>
      <div class="vrow"><b>Where</b><span>{addressLine}</span></div>
      <div class="vrow"><b>Hours</b><span>Range — {site.hours.rangeHuman.toLowerCase()}<br>Course — {site.hours.courseHuman.toLowerCase()}</span></div>
      <div class="vrow"><b>Call</b><span><a href={site.phoneHref}>{site.phone}</a></span></div>
      <div class="vrow"><b>Email</b><span><a href={`mailto:${site.email}`}>{site.email}</a></span></div>
    </div>
    <div class="vmap">
      <iframe title="Map" loading="lazy" referrerpolicy="no-referrer-when-downgrade" src={site.links.map}></iframe>
    </div>
  </section>

  <footer class="foot">
    <p class="fbrand">Christie's Golf Ranch</p>
    <p>{addressLine} · {site.phone}</p>
    <p class="small">Style B draft — not the live site. <a href="/styles">Compare all three styles</a></p>
  </footer>

  <style is:global>
    *{box-sizing:border-box}
    body{margin:0;font-family:'Inter',system-ui,sans-serif;color:#EDE3D2;background:#13201a;line-height:1.65}
    h1,h2,h3{font-family:'Playfair Display',serif;margin:0;line-height:1.08}
    a{color:inherit}
  </style>
  <style>
    :root{--bg:#13201a;--bg2:#0d1712;--panel:#1b2a22;--gold:#E0A53F;--gold-br:#F2C879;--green:#3c6b4d;--cream:#EDE3D2;--soft:#9fae9f}
    .bar{background:#0b130f;color:#9fae9f;text-align:center;font-size:.8rem;font-weight:600;padding:.5rem}
    .bar a{color:var(--gold-br)}

    .nav{position:sticky;top:0;z-index:30;display:flex;align-items:center;justify-content:space-between;gap:1rem;padding:1rem clamp(16px,5vw,56px);background:rgba(13,23,18,.82);backdrop-filter:blur(10px);border-bottom:1px solid rgba(224,165,63,.22)}
    .brand{font-family:'Playfair Display',serif;font-weight:800;font-size:1.2rem;text-decoration:none;color:var(--cream)}
    .brand span{color:var(--gold-br)}
    .links{display:flex;gap:1.8rem}
    .links a{text-decoration:none;font-weight:600;font-size:.82rem;letter-spacing:.08em;text-transform:uppercase;color:var(--soft)}
    .links a:hover{color:var(--gold-br)}
    .navtel{text-decoration:none;font-weight:700;color:var(--cream)}
    @media(max-width:820px){.links{display:none}}

    .btn{display:inline-flex;align-items:center;justify-content:center;background:var(--gold);color:#241804;text-decoration:none;font-weight:700;font-size:.9rem;letter-spacing:.04em;padding:.85rem 1.7rem;border-radius:3px;border:1.5px solid var(--gold);transition:background .2s,transform .15s}
    .btn:hover{background:var(--gold-br);transform:translateY(-2px)}
    .btn.line{background:transparent;color:var(--cream);border-color:rgba(237,227,210,.35)}
    .btn.line:hover{border-color:var(--gold-br);color:var(--gold-br)}
    .btn.sm{padding:.7rem 1.3rem;font-size:.82rem}

    .hero{position:relative;overflow:hidden;padding:clamp(3.5rem,8vw,7rem) clamp(16px,6vw,72px) 0;background:linear-gradient(180deg,#1c2331 0%,#2a2030 36%,#3a2a26 60%,#13201a 100%)}
    .dusk{position:absolute;top:-120px;left:50%;transform:translateX(-50%);width:520px;height:520px;border-radius:50%;background:radial-gradient(circle,rgba(242,200,121,.5),rgba(224,120,63,.18) 45%,transparent 70%);pointer-events:none}
    .ridge{position:absolute;left:0;right:0;bottom:130px;height:160px;background:#0d1712;clip-path:polygon(0 60%,12% 40%,26% 58%,40% 32%,55% 54%,70% 30%,84% 52%,100% 36%,100% 100%,0 100%);opacity:.85}
    .hero-inner{position:relative;z-index:2;max-width:1200px;margin:0 auto}
    .kick{font-size:.76rem;font-weight:700;letter-spacing:.24em;text-transform:uppercase;color:var(--gold-br)}
    .hero h1{font-size:clamp(3rem,9vw,6.6rem);font-weight:800;letter-spacing:-.02em;margin:1.4rem 0 0;color:var(--cream)}
    .hero h1 em{font-style:italic;color:var(--gold-br);font-weight:500}
    .hero p{max-width:50ch;color:#d3c7b2;font-size:1.12rem;margin:1.6rem 0 0}
    .cta{display:flex;flex-wrap:wrap;gap:1rem;margin:2.2rem 0 0}
    .hero-stats{position:relative;z-index:2;max-width:1200px;margin:clamp(3rem,6vw,5rem) auto 0;display:grid;grid-template-columns:repeat(4,1fr);border-top:1px solid rgba(224,165,63,.25)}
    .hero-stats div{padding:1.6rem 1rem;border-right:1px solid rgba(224,165,63,.18)}
    .hero-stats div:last-child{border-right:none}
    .hero-stats b{font-family:'Playfair Display',serif;display:block;font-size:2.4rem;color:var(--gold-br)}
    .hero-stats span{font-size:.72rem;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:var(--soft)}
    @media(max-width:680px){.hero-stats{grid-template-columns:1fr 1fr}.hero-stats div:nth-child(2){border-right:none}}

    .eye{font-weight:700;font-size:.76rem;letter-spacing:.18em;text-transform:uppercase;color:var(--green);margin:0 0 .7rem}
    .eye.gold{color:var(--gold)}
    h2{font-size:clamp(1.9rem,4.4vw,3.1rem);font-weight:700;color:var(--cream);max-width:20ch}
    .lead{color:#c4b9a6;font-size:1.08rem;max-width:52ch;margin:1.1rem 0 0}

    .ed{display:grid;grid-template-columns:auto 1fr;gap:clamp(1.5rem,5vw,4rem);max-width:1200px;margin:0 auto;padding:clamp(3.5rem,7vw,6rem) clamp(16px,6vw,72px);border-bottom:1px solid rgba(224,165,63,.14)}
    .ed-num{font-family:'Playfair Display',serif;font-size:clamp(3rem,6vw,5rem);font-weight:800;color:rgba(224,165,63,.25);line-height:.8}
    .ed-num.light{color:rgba(224,165,63,.4)}
    .rows{margin-top:2rem;border-top:1px solid rgba(224,165,63,.16)}
    .row{display:grid;grid-template-columns:1fr 1.4fr;gap:1.5rem;padding:1.3rem 0;border-bottom:1px solid rgba(224,165,63,.16)}
    .row h3{font-size:1.3rem;color:var(--gold-br);font-weight:700}
    .row p{margin:0;color:#b8ac98}
    @media(max-width:680px){.ed{grid-template-columns:1fr}.row{grid-template-columns:1fr;gap:.3rem}}

    .rates{background:var(--bg2);padding:clamp(3.5rem,7vw,6rem) clamp(16px,6vw,72px)}
    .rates-head{display:flex;align-items:center;gap:1.5rem;max-width:1200px;margin:0 auto 2.5rem}
    .rgrid{display:grid;grid-template-columns:repeat(3,1fr);gap:1.3rem;max-width:1200px;margin:0 auto}
    @media(max-width:880px){.rgrid{grid-template-columns:1fr}}
    .rcard{position:relative;background:var(--panel);border:1px solid rgba(224,165,63,.2);border-radius:6px;padding:1.8rem}
    .rcard.hot{border-color:var(--gold);box-shadow:0 0 0 1px var(--gold),0 24px 50px -28px rgba(224,165,63,.5)}
    .ribbon{position:absolute;top:-12px;left:1.6rem;background:var(--gold);color:#241804;font-size:.66rem;font-weight:800;letter-spacing:.1em;text-transform:uppercase;padding:.3rem .8rem;border-radius:3px}
    .rcard h3{font-size:1.35rem;color:var(--cream);margin-bottom:1rem}
    .line2{display:flex;justify-content:space-between;align-items:baseline;gap:1rem;padding:.7rem 0;border-bottom:1px solid rgba(224,165,63,.16)}
    .line2 span{color:#b8ac98;font-size:.95rem}
    .line2 b{font-family:'Playfair Display',serif;font-size:1.5rem;color:var(--gold-br);white-space:nowrap}
    .line2 b i{font-style:normal;font-size:.78rem;color:var(--soft)}
    .rnote{font-size:.85rem;color:var(--soft);margin:.8rem 0 1.2rem}

    .split{grid-template-columns:1fr 1fr;align-items:start}
    .learn-col.camp{background:var(--panel);border:1px solid rgba(224,165,63,.2);border-radius:6px;padding:1.9rem}
    @media(max-width:820px){.split{grid-template-columns:1fr}}

    .mission{text-align:center;background:var(--green);padding:clamp(3rem,6vw,5rem) clamp(20px,6vw,72px)}
    .mission p{font-family:'Playfair Display',serif;font-style:italic;font-size:clamp(1.3rem,3vw,1.9rem);line-height:1.45;max-width:48ch;margin:0 auto;color:#F4EEDF}
    .mission cite{display:block;margin-top:1.4rem;font-style:normal;font-weight:700;font-size:.76rem;letter-spacing:.16em;text-transform:uppercase;color:var(--gold-br)}

    .visit{display:grid;grid-template-columns:1fr 1.2fr;gap:2.5rem;max-width:1200px;margin:0 auto;padding:clamp(3.5rem,7vw,6rem) clamp(16px,6vw,72px);align-items:stretch}
    @media(max-width:820px){.visit{grid-template-columns:1fr}}
    .vrow{display:grid;grid-template-columns:80px 1fr;gap:1rem;padding:1rem 0;border-bottom:1px solid rgba(224,165,63,.16)}
    .vrow b{color:var(--gold);font-size:.72rem;letter-spacing:.12em;text-transform:uppercase;padding-top:3px}
    .vrow span{color:var(--cream)}
    .vrow a{color:var(--gold-br);text-decoration:none}
    .vmap{border-radius:6px;overflow:hidden;min-height:320px;border:1px solid rgba(224,165,63,.22)}
    .vmap iframe{width:100%;height:100%;min-height:320px;border:0;display:block;filter:sepia(.3) saturate(.85) brightness(.8)}

    .foot{background:var(--bg2);text-align:center;padding:2.6rem 16px;border-top:1px solid rgba(224,165,63,.18)}
    .fbrand{font-family:'Playfair Display',serif;font-weight:800;font-size:1.3rem;color:var(--gold-br);margin:0 0 .4rem}
    .foot p{margin:.25rem 0;color:#b8ac98}
    .foot .small{font-size:.85rem;color:var(--soft)}
    .foot a{color:var(--gold-br)}
  </style>
</body>
</html>
