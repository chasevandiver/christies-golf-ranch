---
import { site } from '../../config/site';
const title = "Style Options — Christie's Golf Ranch";
const options = [
  {
    href: '/styles/open-sky',
    name: 'A · Open Sky',
    blurb: 'Bright, airy, and friendly. Sky-blue and fairway-green with lots of whitespace and soft, rounded shapes — leans hardest into welcoming, beginner- and family-friendly.',
    bg: 'linear-gradient(160deg,#EAF4FB,#F3FBF1)',
    fg: '#16493a', accent: '#2E7D52',
  },
  {
    href: '/styles/twilight',
    name: 'B · Texas Twilight',
    blurb: 'Dark, bold, dramatic. Deep green and dusk-gold with big editorial type and full-bleed imagery — the beauty of an evening session, serious but never country-club.',
    bg: 'linear-gradient(160deg,#16241c,#2a1c2e)',
    fg: '#F4ECDD', accent: '#E0A53F',
  },
  {
    href: '/styles/scorecard',
    name: 'C · Scorecard',
    blurb: 'Crisp, sporty, structured. White, fairway-green and flag-red on a clean grid with tabular numbers — built around posted pricing, no surprises, and the stats.',
    bg: 'linear-gradient(160deg,#ffffff,#f1f4ef)',
    fg: '#14331f', accent: '#C8362B',
  },
];
---
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex" />
  <title>{title}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,500;9..144,600&family=Inter:wght@400;500;700;800&display=swap" rel="stylesheet" />
</head>
<body>
  <main class="chooser">
    <header class="top">
      <p class="kick">Christie's Golf Ranch · Style Exploration</p>
      <h1>Three directions to compare</h1>
      <p class="sub">Each link below is a full, self-contained landing page built with the real ranch content — same facts, three different looks. The current approved site lives at <a href="/">the Home page</a>. These are drafts for review and are not indexed by search.</p>
    </header>
    <div class="grid">
      {options.map((o) => (
        <a class="card" href={o.href} style={`--fg:${o.fg};--accent:${o.accent}`}>
          <div class="swatch" style={`background:${o.bg}`}>
            <span class="dot" style={`background:${o.accent}`}></span>
          </div>
          <div class="body">
            <h2>{o.name}</h2>
            <p>{o.blurb}</p>
            <span class="go">View this style →</span>
          </div>
        </a>
      ))}
    </div>
    <p class="foot">All three keep the brand's low-pressure, family/beginner-friendly tone and the same NAP — {site.address.street}, {site.address.locality}, {site.address.region} · {site.phone}.</p>
  </main>

  <style is:global>
    *{box-sizing:border-box}
    body{margin:0;font-family:'Inter',system-ui,sans-serif;background:#0f1713;color:#1a1a1a}
  </style>
  <style>
    .chooser{max-width:1100px;margin:0 auto;padding:clamp(2.5rem,6vw,5rem) 24px 4rem;color:#EDE7DA}
    .kick{font-size:.78rem;font-weight:800;letter-spacing:.2em;text-transform:uppercase;color:#9ec2a8;margin:0 0 1rem}
    h1{font-family:'Fraunces',serif;font-weight:600;font-size:clamp(2.2rem,5vw,3.4rem);margin:0;line-height:1.08;color:#fff}
    .sub{color:#b9c4ba;font-size:1.05rem;line-height:1.6;max-width:60ch;margin:1.2rem 0 0}
    .sub a{color:#9ed3b0}
    .grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1.4rem;margin:3rem 0 2rem}
    @media(max-width:820px){.grid{grid-template-columns:1fr}}
    .card{display:flex;flex-direction:column;background:#18211c;border:1px solid #2b3a30;border-radius:16px;overflow:hidden;text-decoration:none;color:inherit;transition:transform .18s,border-color .18s,box-shadow .18s}
    .card:hover{transform:translateY(-4px);border-color:var(--accent);box-shadow:0 20px 50px -20px rgba(0,0,0,.6)}
    .swatch{height:140px;position:relative;display:flex;align-items:flex-end;padding:1rem}
    .dot{width:34px;height:34px;border-radius:50%;box-shadow:0 4px 14px rgba(0,0,0,.25)}
    .body{padding:1.5rem}
    .body h2{font-family:'Fraunces',serif;font-weight:600;font-size:1.4rem;margin:0 0 .6rem;color:#fff}
    .body p{color:#aebbb0;font-size:.95rem;line-height:1.55;margin:0 0 1.2rem}
    .go{font-weight:800;font-size:.85rem;letter-spacing:.04em;color:var(--accent)}
    .foot{color:#7e8c81;font-size:.9rem;text-align:center;margin-top:1.5rem}
  </style>
</body>
</html>
