---
import Layout from '../layouts/Layout.astro';
import { site } from '../config/site';
const title = "Visit — Christie's Golf Ranch | Hours, Directions & Contact, Pilot Point TX";
const description = "Visit Christie's Golf Ranch at 920 US Highway 377, Pilot Point, TX 76258. Driving range open every day 8am till dark. Call (214) 317-1488.";
---
<Layout title={title} description={description}>
  <section class="page-hero">
    <div class="wrap">
      <p class="crumbs"><a href="/">Home</a> · Visit</p>
      <h1>Visit the Ranch</h1>
      <p class="lede">Ride out and see the ranch — open every day, no tee times to hit the range.</p>
    </div>
  </section>
  <section class="section on-dark" style="background:var(--leather-soft)">
    <div class="wrap">
      <div class="visit-grid" style="margin-top:0">
        <div>
          <div class="irow"><div class="ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg></div><div><h4>Location</h4><p>{site.address.street}<br>{site.address.locality}, {site.address.regionName} {site.address.postalCode}</p></div></div>
          <div class="irow"><div class="ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="12" cy="12" r="9"/><polyline points="12 7 12 12 16 14"/></svg></div><div><h4>Hours</h4><p>Driving range — {site.hours.rangeHuman.toLowerCase()}<br>Par-3 course — {site.hours.courseHuman.toLowerCase()}</p></div></div>
          <div class="irow"><div class="ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z"/></svg></div><div><h4>Call</h4><p><a href={site.phoneHref}>{site.phone}</a></p></div></div>
          <div class="irow"><div class="ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M4 4h16v16H4z"/><polyline points="22 6 12 13 2 6"/></svg></div><div><h4>Email</h4><p><a href={`mailto:${site.email}`}>{site.email}</a></p></div></div>
        </div>
        <div class="map-card">
          <iframe title={`Map to ${site.name}`} loading="lazy" referrerpolicy="no-referrer-when-downgrade" src={site.links.map}></iframe>
        </div>
      </div>
    </div>
  </section>
</Layout>
