---
import Layout from '../layouts/Layout.astro';
const title = "Our Story — Christie's Golf Ranch | Built on Family Land Since 2008";
const description = "The story of Christie's Golf Ranch — golf enthusiast Jeff Christie's lifelong dream, built in 2008 on Pilot Point family land in honor of his late father, Jim Christie.";
---
<Layout title={title} description={description}>
  <section class="page-hero">
    <div class="wrap">
      <p class="crumbs"><a href="/">Home</a> · Our Story</p>
      <h1>Our Story</h1>
      <p class="lede">A first-class golf venue, built on family land — the lifelong dream of golf enthusiast Jeff Christie.</p>
    </div>
  </section>
  <section class="section">
    <div class="wrap">
      <p class="stub-note">Full story page coming next — building the Home page first for review. Jeff's bio, the ranch history, and the mission will live here.</p>
      <div style="margin-top:1.8rem"><a class="btn btn-brass" href="/">Back to Home</a></div>
    </div>
  </section>
</Layout>
