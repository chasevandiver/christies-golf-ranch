---
import Layout from '../layouts/Layout.astro';
import Photo from '../components/Photo.astro';
import { site, lessonPackages, checkoutHref } from '../config/site';
const title = "Golf Lessons in Pilot Point, TX — Private Instruction with Jeff Christie";
const description = "Private golf lessons with Jeff Christie at Christie's Golf Ranch in Pilot Point, TX. Single hours and 3, 5, and 7-lesson packages for individuals, families, and teams.";
---
<Layout title={title} description={description}>
  <section class="page-hero">
    <div class="wrap">
      <p class="crumbs"><a href="/">Home</a> · Instruction</p>
      <h1>Instruction</h1>
      <p class="lede">Private coaching with Jeff Christie — refine what works, don't rebuild it. For individuals, families, and the local high school team.</p>
    </div>
  </section>

  <!-- APPROACH -->
  <section class="section">
    <div class="wrap about-grid">
      <div class="about-copy reveal">
        <span class="eyebrow">The Approach</span>
        <h2>Golf is a mental game</h2>
        <p>Jeff coaches to enhance the skills you already have and build from there — not to tear your swing down and start over. The goal is a repeatable, confident motion that holds up under pressure on the course.</p>
        <p>Lessons are one-on-one and meet you where you are: a first-timer learning grip and posture, a weekend player chasing more consistency, or a competitive junior sharpening for a season. Families and the local high school team are all welcome.</p>
        <p class="sig">"There are not many people living out their dream. I am doing that." — Jeff Christie</p>
        <div style="margin-top:1.8rem">
          <a class="btn btn-dark" href={site.phoneHref}>Call {site.phone} to Book</a>
        </div>
      </div>
      <Photo class="reveal" marker="Jeff giving a lesson on the range" tag="lesson in progress" scene="range" />
    </div>
  </section>

  <!-- PACKAGES — book & pay online (ticket 1.1, Clover Payment Links) -->
  <section class="section on-dark">
    <div class="wrap">
      <div class="reveal">
        <span class="eyebrow">Book &amp; Pay Online</span>
        <h2>Single hours or save with a package</h2>
        <p class="intro">Pay securely online and we'll be in touch to set your time — or call Jeff directly, whichever you prefer. Packages can be split across family members.</p>
      </div>
      <div class="pgrid c2 reveal" style="margin-top:2.6rem">
        {lessonPackages.map((pkg) => {
          const live = Boolean(pkg.checkout);
          return (
            <div class={`pcard${pkg.id === 'pack3' ? ' hi' : ''}`}>
              {pkg.id === 'pack3' && <span class="flag">Popular</span>}
              <h4>{pkg.label}</h4>
              <div class="amt">{pkg.price}</div>
              <p class="desc">{pkg.note}</p>
              {/* Clover Payment Link when set; falls back to phone until then. */}
              <div class="cta">
                <a
                  class={`btn ${pkg.id === 'pack3' ? 'btn-brass' : 'btn-dark'}`}
                  href={checkoutHref(pkg)}
                  data-cta="book-lesson"
                  {...(live ? { target: '_blank', rel: 'noopener' } : {})}
                >
                  {live ? `Book & Pay · ${pkg.price}` : `Call to Book · ${site.phone}`}
                </a>
              </div>
            </div>
          );
        })}
      </div>
      <p class="editnote reveal" style="color:var(--cream-soft);border-color:var(--brass)">
        Families &amp; groups and the local high school team are welcome — call
        <a href={site.phoneHref} style="color:var(--brass-br);font-weight:800"> {site.phone}</a> about group and team rates.
      </p>
      <div class="reveal" style="margin-top:1.8rem">
        <a class="btn btn-brass" href="/pricing">See Full Pricing</a>
      </div>
    </div>
  </section>

  <!-- BOOK CTA -->
  <section class="section">
    <div class="wrap reveal" style="text-align:center">
      <span class="eyebrow" style="justify-content:center">Schedule Your Coaching</span>
      <h2 style="margin:0 auto">Call Jeff directly to book</h2>
      <p class="intro" style="margin:1.1rem auto 2rem">Reserve a single lesson or a package over the phone — Jeff will help you pick the right starting point.</p>
      <div class="hero-actions" style="justify-content:center">
        <a class="btn btn-brass btn-lg" href={site.phoneHref}>Call {site.phone}</a>
        <a class="btn btn-dark btn-lg" href={`mailto:${site.email}`}>Email Us</a>
      </div>
    </div>
  </section>
</Layout>
