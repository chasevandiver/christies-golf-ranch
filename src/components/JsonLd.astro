---
import { site } from '../config/site';

/**
 * LocalBusiness (GolfCourse) structured data, generated from the shared NAP
 * config and rendered on EVERY page via Layout. One source of truth — keeps
 * the schema NAP identical to what's shown on the page.
 */
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'GolfCourse',
  name: site.name,
  description:
    'The premier all-grass golf ranch in North Texas — a driving range and 9-hole par-3 golf course.',
  url: site.url + '/',
  telephone: site.phoneE164,
  email: site.email,
  address: {
    '@type': 'PostalAddress',
    streetAddress: site.address.street,
    addressLocality: site.address.locality,
    addressRegion: site.address.region,
    postalCode: site.address.postalCode,
    addressCountry: site.address.country,
  },
  geo: {
    '@type': 'GeoCoordinates',
    latitude: site.geo.latitude,
    longitude: site.geo.longitude,
  },
  openingHours: site.hours.schema,
  priceRange: site.priceRange,
  sameAs: [site.social.facebook, site.social.instagram, site.social.yelp],
};
---
<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
