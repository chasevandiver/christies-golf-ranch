---
/**
 * Styled photo placeholder. Real photography drops in later — every instance
 * leaves a clear `<!-- PHOTO: ... -->` marker (see `marker` prop) so the slots
 * are easy to find. `scene` picks one of a few framed SVG backdrops.
 */
interface Props {
  /** What real photo goes here, e.g. "the range at first light". */
  marker: string;
  /** Caption shown on the placeholder tag. */
  tag: string;
  /** Backdrop variant. */
  scene?: 'range' | 'green' | 'dawn' | 'plain';
  /** Extra classes (e.g. "tall", "wide" for the gallery grid). */
  class?: string;
}
const { marker, tag, scene = 'range', class: className } = Astro.props;
---
<Fragment set:html={`<!-- PHOTO: ${marker} -->`} />
<div class={`photo ${className ?? ''}`} aria-label="Photo placeholder">
  {scene === 'range' && (
    <svg class="scene" viewBox="0 0 600 480" preserveAspectRatio="xMidYMid slice" aria-hidden="true">
      <rect width="600" height="480" fill="#4C3826" />
      <path d="M0 300 C150 280 320 320 460 300 C540 290 600 300 600 298 L600 480 L0 480Z" fill="#3E4A2B" />
      <path d="M0 360 C200 344 400 380 600 358 L600 480 L0 480Z" fill="#44542F" />
      <g stroke="#2A1D12" stroke-width="4"><line x1="60" y1="320" x2="60" y2="380" /><line x1="180" y1="316" x2="180" y2="380" /><line x1="300" y1="320" x2="300" y2="382" /><line x1="40" y1="338" x2="320" y2="334" /></g>
      <circle cx="470" cy="120" r="46" fill="#D9B878" opacity=".8" />
    </svg>
  )}
  {scene === 'green' && (
    <svg class="scene" viewBox="0 0 600 480" preserveAspectRatio="xMidYMid slice" aria-hidden="true">
      <rect width="600" height="480" fill="#4C3826" />
      <path d="M0 300 C150 280 320 320 460 300 C600 290 600 300 600 298 L600 480 L0 480Z" fill="#44542F" />
      <line x1="420" y1="360" x2="420" y2="250" stroke="#D4B26C" stroke-width="5" />
      <path d="M420 250l34 12-34 12z" fill="#D4B26C" />
      <ellipse cx="420" cy="362" rx="40" ry="7" fill="#3E4A2B" />
    </svg>
  )}
  {scene === 'dawn' && (
    <svg class="scene" viewBox="0 0 600 480" preserveAspectRatio="xMidYMid slice" aria-hidden="true">
      <rect width="600" height="480" fill="#4C3826" />
      <path d="M0 340 C200 322 400 360 600 338 L600 480 L0 480Z" fill="#44542F" />
      <circle cx="120" cy="110" r="40" fill="#D9B878" opacity=".8" />
    </svg>
  )}
  {scene === 'plain' && (
    <svg class="scene" viewBox="0 0 600 480" preserveAspectRatio="xMidYMid slice" aria-hidden="true">
      <rect width="600" height="480" fill="#4C3826" />
      <path d="M0 360 C200 344 400 380 600 358 L600 480 L0 480Z" fill="#44542F" />
    </svg>
  )}
  <span class="tag"><b>Add photo:</b> {tag}</span>
</div>
