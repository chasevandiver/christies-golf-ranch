---
import { site } from '../config/site';

/**
 * Sticky mobile action bar (ticket 3.3) — persistent Call + Directions on small
 * screens, where most local "near me" traffic lands. Hidden on desktop, where
 * the header already carries the phone and nav. The `data-cta` hooks are ready
 * for GA4 event tracking once a Measurement ID is provided (ticket 3.4).
 */
---
<nav class="stickybar" aria-label="Quick actions">
  <a class="sb-btn call" href={site.phoneHref} data-cta="call">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
    Call
  </a>
  <a class="sb-btn dir" href={site.links.directions} target="_blank" rel="noopener" data-cta="directions">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
    Directions
  </a>
</nav>

<style>
  .stickybar { display: none; }
  @media (max-width: 760px) {
    .stickybar {
      display: grid;
      grid-template-columns: 1fr 1fr;
      position: fixed;
      left: 0; right: 0; bottom: 0;
      z-index: 80;
      background: rgba(39,26,16,0.96);
      backdrop-filter: blur(8px);
      border-top: 1px solid var(--line-d, rgba(176,136,63,0.32));
      padding: 0.55rem 0.6rem calc(0.55rem + env(safe-area-inset-bottom));
      gap: 0.55rem;
    }
    .sb-btn {
      display: inline-flex; align-items: center; justify-content: center; gap: 0.5rem;
      font-family: 'Mulish', system-ui, sans-serif;
      font-weight: 800; font-size: 0.9rem; letter-spacing: 0.04em;
      text-transform: uppercase; text-decoration: none;
      padding: 0.85rem 1rem; border-radius: 5px; line-height: 1;
    }
    .sb-btn svg { width: 18px; height: 18px; }
    .sb-btn.call { background: var(--brass, #B0883F); color: var(--leather-deep, #271A10); }
    .sb-btn.dir { background: transparent; color: var(--cream, #F1E8D4); border: 1.5px solid rgba(241,232,212,0.4); }
    /* lift the page so the bar never covers footer content */
    :global(footer) { margin-bottom: 64px; }
  }
</style>
